source "https://rubygems.org"

gemspec path: ".."

gem "rake"
gem "rake-compiler"
gem "minitest"
gem "combustion"
gem "rails", "~> 8.0.0"
gem "sqlite3"
gem "mysql2", platform: :ruby
gem "trilogy", platform: :ruby
gem "pg", platform: [:ruby, :windows]
gem "tzinfo-data", platform: :windows
gem "ruby_memcheck"
